{
  "manifest_version": 3,
  "name": "Cleaner-utils",
  "description": "Ищет дубли в OpenEnds, массово группирует их и переносит данные проекта из Pyrus в Cleaner.",
  "version": "1.0.0",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_title": "Cleaner-utils",
    "default_icon": {
      "16": "icons/logo.png",
      "32": "icons/logo.png",
      "48": "icons/logo.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://clr.env7.biz/lk*",
        "http://clr.env7.biz/lk*",
        "https://pyrus.com/t*",
        "https://www.pyrus.com/t*"
      ],
      "js": [
        "xlsx.full.min.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/logo.png",
    "32": "icons/logo.png",
    "48": "icons/logo.png",
    "128": "icons/logo.png"
  }
}
