{
  "manifest_version": 3,
  "name": "Cleaner Assistant",
  "description": "Группировка OpenEnds, проверка OPENEND-OB с ручной чисткой, перенос данных проекта из Pyrus в Cleaner, фильтры проектов.",
  "version": "1.0.0",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_title": "Cleaner Assistant",
    "default_icon": {
      "16": "icons/logo.png",
      "32": "icons/logo.png",
      "48": "icons/logo.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://clr.env7.biz/lk*",
        "http://clr.env7.biz/lk*",
        "https://pyrus.com/t*",
        "https://www.pyrus.com/t*"
      ],
      "js": [
        "xlsx.full.min.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/logo.png",
    "32": "icons/logo.png",
    "48": "icons/logo.png",
    "128": "icons/logo.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/inc.png", "icons/speed.png", "icons/manual.png", "icons/table.png"],
      "matches": ["https://clr.env7.biz/*", "http://clr.env7.biz/*"]
    }
  ]
}
