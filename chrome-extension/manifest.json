{
  "manifest_version": 3,
  "name": "Cleaner Assistant",
  "description": "Внутренний инструмент для Cleaner и Pyrus: OpenEnds, VerifyMain, ручная чистка и перенос данных проекта.",
  "version": "1.0.2",
  "permissions": [
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://clr.env7.biz/*",
    "https://pyrus.com/*",
    "https://www.pyrus.com/*"
  ],
  "action": {
    "default_title": "Cleaner Assistant",
    "default_icon": {
      "16": "icons/logo.png",
      "32": "icons/logo.png",
      "48": "icons/logo.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://clr.env7.biz/lk*",
        "https://pyrus.com/t*",
        "https://www.pyrus.com/t*"
      ],
      "css": [
        "content/styles/styles.css"
      ],
      "js": [
        "xlsx.full.min.js",
        "content/base/globals.js",
        "content/base/page-init.js",
        "content/base/verify-bootstrap.js",
        "content/base/openends-shortcut.js",
        "content/common/dom-utils.js",
        "content/common/common-utils.js",
        "content/cleaner-projects/cleaner-projects-author-filter.js",
        "content/cleaner-projects/cleaner-projects-favorites.js",
        "content/pyrus/pyrus.js",
        "content/pyrus/pyrus-payload.js",
        "content/pyrus/pyrus-prefill.js",
        "content/pyrus/cleaner-form-fill.js",
        "content/pyrus/cleaner-autofill.js",
        "content/storage/storage.js",
        "content/verify/verify-question-utils.js",
        "content/verify/verify-manual-storage.js",
        "content/verify/verify-rating.js",
        "content/verify/project-edit-stats.js",
        "content/verify/verify-modal.js",
        "content/verify/verify-row-context.js",
        "content/verify/verify-index.js",
        "content/verify/verify-row-decorate.js",
        "content/openends/openends-data.js",
        "content/openends/openends-actions.js",
        "content/openends/openends-ui.js",
        "content/base/init.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/logo.png",
    "32": "icons/logo.png",
    "48": "icons/logo.png",
    "128": "icons/logo.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/inc.png",
        "icons/speed.png",
        "icons/manual.png",
        "icons/table.png"
      ],
      "matches": ["https://clr.env7.biz/*"]
    }
  ]
}
