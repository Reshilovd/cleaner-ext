{
  "manifest_version": 3,
  "name": "Cleaner Assistant",
  "description": "Группировка OpenEnds, проверка OPENEND-OB с ручной чисткой, перенос данных проекта из Pyrus в Cleaner, фильтры проектов.",
  "version": "1.0.0",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_title": "Cleaner Assistant",
    "default_icon": {
      "16": "icons/logo.png",
      "32": "icons/logo.png",
      "48": "icons/logo.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://clr.env7.biz/lk*",
        "http://clr.env7.biz/lk*",
        "https://pyrus.com/t*",
        "https://www.pyrus.com/t*"
      ],
      "js": [
        "xlsx.full.min.js",
        "content/01-base.js",
        "content/01-dom-utils.js",
        "content/01-common-utils.js",
        "content/02-cleaner-projects-author-filter.js",
        "content/02-cleaner-projects-favorites.js",
        "content/03-pyrus.js",
        "content/03-pyrus-payload.js",
        "content/03-pyrus-prefill.js",
        "content/03-cleaner-form-fill.js",
        "content/03-cleaner-autofill.js",
        "content/04-storage.js",
        "content/05-styles.js",
        "content/05-verify-question-utils.js",
        "content/05-verify-manual-storage.js",
        "content/05-verify-rating.js",
        "content/05-verify-modal.js",
        "content/05-verify-row-context.js",
        "content/05-verify-index.js",
        "content/05-verify-row-decorate.js",
        "content/06-openends-panel.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/logo.png",
    "32": "icons/logo.png",
    "48": "icons/logo.png",
    "128": "icons/logo.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/inc.png", "icons/speed.png", "icons/manual.png", "icons/table.png"],
      "matches": ["https://clr.env7.biz/*", "http://clr.env7.biz/*"]
    }
  ]
}
